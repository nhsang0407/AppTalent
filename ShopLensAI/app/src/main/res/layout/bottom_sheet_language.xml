<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/space_xl">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/space_l"
        android:text="@string/language"
        android:textAppearance="@style/Text.Title"
        android:textSize="18sp" />

    <!-- English row -->
    <LinearLayout
        android:id="@+id/rowEnglish"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🇬🇧 English"
            android:textAppearance="@style/Text.Body"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/icCheckEnglish"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="@null"
            android:visibility="gone"
            app:tint="@color/primary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline_variant" />

    <!-- Vietnamese row -->
    <LinearLayout
        android:id="@+id/rowVietnamese"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🇻🇳 Tiếng Việt"
            android:textAppearance="@style/Text.Body"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/icCheckVietnamese"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="@null"
            android:visibility="gone"
            app:tint="@color/primary" />
    </LinearLayout>

</LinearLayout>
