<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/space_s">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_product"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:contentDescription="@string/cd_product_image"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_product_placeholder"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.ShopLens.BottomSheet" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_m"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Product name"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body" />

        <TextView
            android:id="@+id/tv_qty_price"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 × $0.00"
            android:textAppearance="@style/Text.Caption" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_subtotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$0.00"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:fontFamily="monospace" />
</LinearLayout>
